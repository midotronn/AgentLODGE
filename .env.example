# LLM selection agent, costume description agent, and image generation (OpenAI)
# OPENAI_API_KEY is required for the costume description agent even when IMAGE_BACKEND=gemini.
IMAGE_BACKEND=openai
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1

# Pipeline paths
OUTPUT_DIR=./outputs
LODGE_CODE_PATH=../Runs/LODGE
EDGE_CODE_PATH=../Runs/EDGE
LODGE_WEIGHTS_PATH=../Runs/LODGE/exp/Local_Module/FineDance_FineTuneV2_Local/checkpoints/epoch=299.ckpt
LODGE_GLOBAL_WEIGHTS_PATH=../Runs/LODGE/exp/Global_Module/FineDance_Global/checkpoints/epoch=2999.ckpt
EDGE_WEIGHTS_PATH=../Runs/EDGE/checkpoint.pt

# Optional: LODGE genre (FineDance label); default is neutral/pop-style Hiphop
LODGE_GENRE=Hiphop
AGENTLODGE_MIN_AUDIO_SECONDS=20
AGENTLODGE_MAX_EDGE_SLICES=7
AGENTLODGE_PARALLEL=0

# Dance video rendering: "stick" (default, no extra assets) or "blender" (3D mesh in an
# EDGE-style studio: cyclorama backdrop, spotlight vignette, follow camera).
# The Blender path needs Blender installed. Pick the character with RENDER_CHARACTER:
#   "smplx" - smooth SMPL-X body; needs the licence-gated SMPL-X body model
#             (https://smpl-x.is.tue.mpg.de). SMPLX_MODEL_DIR must contain
#             smplx/SMPLX_NEUTRAL.npz. UV + texture are optional.
#   "ybot"  - EDGE's segmented Mixamo Y-Bot robot; needs EDGE's ybot.fbx (from EDGE's
#             SMPL-to-FBX/, https://github.com/Stanford-TML/EDGE). No SMPL-X model needed.
AGENTLODGE_RENDER_BACKEND=stick
AGENTLODGE_RENDER_CHARACTER=smplx
BLENDER_BIN=
SMPLX_MODEL_DIR=
SMPLX_UV_PATH=
SMPLX_TEXTURE_PATH=
YBOT_FBX_PATH=
# Robot base colour (r,g,b in 0-1) for the Y-Bot character.
AGENTLODGE_RENDER_COLOR=0.5,0.5,0.52

